# FRC Pit Safety Monitor Configuration

# Detection
CONFIRM_FRAMES=8
MIN_CONF=0.70

# Performance
PROCESS_EVERY_N=2
TFLITE_THREADS=2

# Camera (auto = auto-detect, -1 = Pi Camera, 0+ = USB index)
CAMERA_INDEX=auto
CAM_RETRY_DELAY=5

# Training data collection (seconds between saves, 0 = disabled)
DATA_SAVE_INT=0

# Display (1 = fullscreen kiosk, DEMO_MODE = touchless auto-start)
FULLSCREEN=1
DEMO_MODE=1

# Model path (empty = auto-detect first .tflite in directory)
MODEL_PATH=
